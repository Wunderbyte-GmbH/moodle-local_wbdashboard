{{!
    @template local_wb_dashboard/chart

    Renders a chart canvas and loads its fully-built config via the web service.

    Context variables required for this template:
    * canvasid - Unique DOM id for the canvas.
    * chartid - Stable chart id used for per-chart settings.
    * title - Accessible chart title (aria-label).
    * width - Max width in rem.
    * height - Height in rem.
    * pageid - Page identifier for shared filter state.
    * consumes - JSON array of filter keys this chart reacts to.
    * wsargs - JSON object of web-service arguments (source, type, params, ...).
    * palettename - Active palette name; added as a wb-palette-NAME scope class.
    * cansettings - Whether to show the colour settings gear.

    Example context (json):
    {
        "canvasid": "local-dashboard-chart-1",
        "chartid": "c0123456789ab",
        "title": "Progress",
        "width": 32,
        "height": 20,
        "pageid": "default",
        "consumes": "[]",
        "wsargs": "{}",
        "palettename": "standard",
        "cansettings": true
    }
}}
<div class="local-dashboard-chart wb-palette-{{palettename}}" data-region="chart-wrapper" data-chartid="{{chartid}}">
    {{#cansettings}}
    <div class="local-dashboard-chart-toolbar">
        <button type="button" class="btn btn-icon btn-sm local-dashboard-chart-settings"
            data-action="chart-settings"
            data-chartid="{{chartid}}"
            title="{{#str}}chartsettings:gear, local_wb_dashboard{{/str}}"
            aria-label="{{#str}}chartsettings:gear, local_wb_dashboard{{/str}}">
            {{#pix}}i/settings, core{{/pix}}
        </button>
    </div>
    {{/cansettings}}
    <div class="local-dashboard-chart-container"
         style="position: relative; width: 100%; max-width: {{width}}rem; height: {{height}}rem; margin: 0 auto;">
        <div class="local-dashboard-chart-skeleton" aria-hidden="true"></div>
        <canvas id="{{canvasid}}"
            role="img"
            aria-label="{{title}}"
            aria-busy="true"
            data-chartid="{{chartid}}"
            data-pageid="{{pageid}}"
            data-consumes="{{consumes}}"
            data-wsargs="{{wsargs}}"
            style="display: none; width: 100%; height: 100%;">
        </canvas>
    </div>
</div>

{{#js}}
require(['local_wb_dashboard/chart'], function(chart) {
    chart.init({{#quote}}{{canvasid}}{{/quote}});
});
{{/js}}
{{#cansettings}}
{{#js}}
require(['local_wb_dashboard/chart_settings'], function(chartSettings) {
    chartSettings.init();
});
{{/js}}
{{/cansettings}}
