{{!
    @template local_wb_dashboard/digits

    Renders a single numeric value (number, count or percentage) as a styleable
    field and loads its value via the web service.

    Every id is deterministic and constant so it can be targeted from CSS: the
    wrapper is domid, the value element domid-value, the label domid-label.

    Context variables required for this template:
    * domid - Deterministic, constant DOM id for the field wrapper.
    * valueid - Constant DOM id for the value element.
    * labelid - Constant DOM id for the label element.
    * label - Initial (author-supplied) label; may be overwritten by the web service.
    * pageid - Page identifier for shared filter state.
    * consumes - JSON array of filter keys this field reacts to.
    * wsargs - JSON object of web-service arguments (source, display, params, ...).

    Example context (json):
    {
        "domid": "local-dashboard-digits-ab12cd34ef56",
        "valueid": "local-dashboard-digits-ab12cd34ef56-value",
        "labelid": "local-dashboard-digits-ab12cd34ef56-label",
        "label": "Active users",
        "pageid": "default",
        "consumes": "[]",
        "wsargs": "{}"
    }
}}
<div class="local-dashboard-digits" id="{{domid}}"
     data-region="digits-wrapper"
     data-pageid="{{pageid}}"
     data-consumes="{{consumes}}"
     data-wsargs="{{wsargs}}"
     aria-busy="true">
    <div class="local-dashboard-digits-skeleton" aria-hidden="true"></div>
    <div class="local-dashboard-digits-value" id="{{valueid}}">&nbsp;</div>
    <div class="local-dashboard-digits-label" id="{{labelid}}">{{label}}</div>
</div>

{{#js}}
require(['local_wb_dashboard/digits'], function(digits) {
    digits.init({{#quote}}{{domid}}{{/quote}});
});
{{/js}}
