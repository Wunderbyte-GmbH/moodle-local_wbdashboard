{{!
    @template local_wb_dashboard/chartfilter

    Renders a page-level filter control that publishes to the filter bus.

    Context variables required for this template:
    * id - Unique DOM id for the control.
    * key - Logical filter key.
    * type - Filter type (select|date|text|number).
    * label - Visible label.
    * value - Current value.
    * pageid - Page identifier for shared filter state.
    * islocked - The value is server-forced for this user: render it statically.
    * isselect / isdate / istext / isnumber - Type flags (all false when locked).
    * options - For select: list of {value, label, selected}.
    * palettename - Active palette name; added as a wb-palette-NAME scope class.

    Example context (json):
    {
        "id": "local-dashboard-filter-1",
        "key": "period",
        "type": "date",
        "label": "Period",
        "value": "",
        "pageid": "default",
        "isdate": true,
        "isselect": false,
        "istext": false,
        "isnumber": false,
        "options": [],
        "palettename": "standard"
    }
}}
<div class="local-dashboard-filter form-group wb-palette-{{palettename}}" data-region="chart-filter"
     data-filter-key="{{key}}" data-filter-type="{{type}}" data-pageid="{{pageid}}">
    <label for="{{id}}" class="local-dashboard-filter-label">{{label}}</label>
    {{#islocked}}
        <span id="{{id}}" class="form-control-plaintext local-dashboard-filter-locked">{{value}}</span>
    {{/islocked}}
    {{#isselect}}
        <select id="{{id}}" class="custom-select" data-filter-control="1">
            <option value="">{{#str}}choosedots{{/str}}</option>
            {{#options}}
                <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
            {{/options}}
        </select>
    {{/isselect}}
    {{#isdate}}
        <input type="date" id="{{id}}" class="form-control" value="{{value}}" data-filter-control="1">
    {{/isdate}}
    {{#istext}}
        <input type="text" id="{{id}}" class="form-control" value="{{value}}" data-filter-control="1">
    {{/istext}}
    {{#isnumber}}
        <input type="number" id="{{id}}" class="form-control" value="{{value}}" data-filter-control="1">
    {{/isnumber}}
    {{#ismap}}
        <input type="hidden" id="{{id}}" value="{{value}}" data-filter-control="1">
        <p class="wb-region-readout" aria-live="polite" data-region="readout"
           data-emptytext="{{#str}}mapfilter:noregion, local_wb_dashboard{{/str}}">
            {{#value}}{{value}}{{/value}}{{^value}}{{#str}}mapfilter:noregion, local_wb_dashboard{{/str}}{{/value}}
        </p>
        <div class="wb-region-map">
            <svg viewBox="{{viewbox}}" role="group" aria-label="{{#str}}mapfilter:maplabel, local_wb_dashboard{{/str}}">
                {{#regions}}
                    <path class="wb-region{{#selected}} selected{{/selected}}" d="{{d}}"
                          data-value="{{value}}" data-name="{{name}}"
                          tabindex="0" role="button" aria-label="{{name}}"
                          aria-pressed="{{#selected}}true{{/selected}}{{^selected}}false{{/selected}}"></path>
                {{/regions}}
            </svg>
        </div>
    {{/ismap}}
</div>

{{^islocked}}
{{#js}}
require(['local_wb_dashboard/filterbus'], function(filterbus) {
    filterbus.registerControl({{#quote}}{{id}}{{/quote}});
});
{{#ismap}}
require(['local_wb_dashboard/regionmap'], function(regionmap) {
    regionmap.init({{#quote}}{{id}}{{/quote}});
});
{{/ismap}}
{{/js}}
{{/islocked}}
